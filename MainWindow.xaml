<Window x:Class="Bevolkerung.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bevolkerung"
        mc:Ignorable="d"
        Title="Németország anonimizált lakossági adatai" Height="750" Width="1300">
    <Grid Margin="10,10,0,0">
        <ComboBox x:Name="feladatComboBox" HorizontalAlignment="Left" Height="28" Margin="23,10,0,0" VerticalAlignment="Top" Width="63" SelectionChanged="feladatComboBox_SelectionChanged" />
        <Label Content="feladat egy mondatos megoldása:" HorizontalAlignment="Left" Height="28" Margin="104,14,0,0" VerticalAlignment="Top" Width="217" FontWeight="Bold"/>
        <Label x:Name="MegoldasMondatos" Content="" HorizontalAlignment="Left" Margin="310,14,0,0" VerticalAlignment="Top" Width="291"/>
        <Label Content="Megoldásként leszűrt sorok" HorizontalAlignment="Left" Height="31" Margin="23,56,0,0" VerticalAlignment="Top" Width="208" FontWeight="Bold"/>
        <DataGrid x:Name="MegoldasTeljes" HorizontalAlignment="Left" Height="310" Margin="23,118,0,0" VerticalAlignment="Top" Width="auto" AutoGenerateColumns="False" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Nem" Binding="{Binding Nem}"/>
                <DataGridTextColumn Header="Születési év" Binding="{Binding SzuletesiEv}"/>
                <DataGridTextColumn Header="Súly" Binding="{Binding Suly}"/>
                <DataGridTextColumn Header="Magasság" Binding="{Binding Magassag}"/>
                <DataGridTextColumn Header="Dohányzik" Binding="{Binding DohanyzikSzovegesen}"/>
                <DataGridTextColumn Header="Nemzetiség" Binding="{Binding Nemzetiseg}"/>
                <DataGridTextColumn Header="Népcsoport" Binding="{Binding Nepcsoport}"/>
                <DataGridTextColumn Header="Tartomány" Binding="{Binding Tartomany}"/>
                <DataGridTextColumn Header="Nettó éves jövedelem" Binding="{Binding NettoJovedelem}"/>
                <DataGridTextColumn Header="Iskolai végzettség" Binding="{Binding IskolaiVegzettseg}"/>
                <DataGridTextColumn Header="Politikai nézet" Binding="{Binding PolitikaiNezet }"/>
                <DataGridTextColumn Header="Aktív szavazó" Binding="{Binding AktivSzavazoSzovegesen}"/>
                <DataGridTextColumn Header="Évi sörfogyasztás" Binding="{Binding SorFogyasztasEventeSzovegesen }"/>
                <DataGridTextColumn Header="Évi krumplifogyasztás" Binding="{Binding KrumpliFogyasztasEventeSzovegesen }"/>
            </DataGrid.Columns>
        </DataGrid>
        <ListBox x:Name="MegoldasLista" HorizontalAlignment="Left" Height="198" Margin="23,473,0,0" VerticalAlignment="Top" Width="494" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        <Label Content="Listás megoldás" HorizontalAlignment="Left" Height="36" Margin="22,437,0,0" VerticalAlignment="Top" Width="190" FontWeight="Bold"/>


    </Grid>
</Window>
